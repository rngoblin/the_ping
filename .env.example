# Copy this file to .env.local for local secrets/config.
# Do not commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy Supabase projects may expose an anon key instead.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_FEEDBACK_URL=

# V0.4 can use Supabase realtime when these values are present.
# If either value is missing, PING falls back to mock realtime.
# Use a browser-safe Supabase Publishable key (`sb_publishable_...`) when available.
# Legacy anon keys are also browser-safe, but new deploys should prefer publishable keys.
# Do not use a secret/service-role key.

# Do not put private server-side API keys in this GitHub Pages frontend.
# Anything prefixed NEXT_PUBLIC_ is bundled into the browser.
